# ─── Banco de dados ────────────────────────────────────────────────────────────
# Railway injeta automaticamente DATABASE_URL ao adicionar o plugin PostgreSQL
DATABASE_URL=postgresql://localhost:5432/diabetessharp

# ─── Servidor ──────────────────────────────────────────────────────────────────
# Railway injeta PORT automaticamente — não precisa definir em produção
PORT=4000
NODE_ENV=development

# ─── URLs da aplicação ─────────────────────────────────────────────────────────
# URL pública do app (usada em e-mails e redirecionamentos)
APP_URL=http://localhost:3000
# Domínio do cliente para CORS (em produção = mesmo domínio do APP_URL)
CLIENT_URL=http://localhost:4001

# ─── Client (injetado no browser como window.HWS_AUTH_URL — mesmo padrão hws-ed-web-app) ─
# URL do HWS Auth para login (redirect). Obrigatório em produção.
# Em deploy estático (sem server), configure HWS_AUTH_URL no ambiente de build antes de rodar npm run build.
HWS_AUTH_URL=https://auth.helping-you-works-smarter.com

# ─── E-mail (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=DiabetesSharp <noreply@diabetessharp.com>
