# ─── Banco de dados ────────────────────────────────────────────────────────────
# Railway injeta automaticamente DATABASE_URL ao adicionar o plugin PostgreSQL
DATABASE_URL=postgresql://localhost:5432/diabetessharp

# ─── Servidor ──────────────────────────────────────────────────────────────────
# Railway injeta PORT automaticamente — não precisa definir em produção
PORT=4000
NODE_ENV=development

# ─── URLs da aplicação ─────────────────────────────────────────────────────────
# URL pública do app (usada em e-mails e redirecionamentos)
APP_URL=http://localhost:3000
# Domínio do cliente para CORS (em produção = mesmo domínio do APP_URL)
CLIENT_URL=http://localhost:4001

# ─── E-mail (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=DiabetesSharp <noreply@diabetessharp.com>
