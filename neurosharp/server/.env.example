# =============================================================================
# diabetessharp/neurosharp — Environment Variables
# =============================================================================
# Copy to .env and fill in your values. Aligns with hws-ed-web-app.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# App & Server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3002

# URL pública da aplicação (emails, redirects, CORS)
APP_URL=http://localhost:3002

# Origens CORS adicionais (separadas por vírgula)
# Ex: CORS_EXTRA_ORIGINS=https://meu-app.railway.app
# CORS_EXTRA_ORIGINS=

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://localhost:5432/neurosharp

# -----------------------------------------------------------------------------
# Auth & Security
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ISSUER=https://auth.hws.com
HWS_AUTH_URL=http://localhost:3000

# Roles permitidas (CSV). Ex: HWSUser.diabetessharp.Read,HWSAdmin.diabetessharp.All
# ALLOWED_ROLES=

# Domínio para cookies em produção. Ex: .diabetessharp.com
# COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=NeuroSharp <noreply@neurosharp.com>

# -----------------------------------------------------------------------------
# CartPanda / Carpanda (Pagamentos)
# -----------------------------------------------------------------------------
CARPANDA_MAIN_URL=https://its-brazilian-llc.mycartpanda.com/checkout/208723849:1
# CARPANDA_MAIN_DISCOUNT_URL=
# CARPANDA_RECIPE_BUMP_URL=
# CARPANDA_UPSELL1_URL=
# CARPANDA_UPSELL2_URL=
# CARPANDA_UPSELL3_URL=

# -----------------------------------------------------------------------------
# Storage (opcional)
# -----------------------------------------------------------------------------
# HWS_FILES_URL=
# STORAGE_PATH=./uploads
