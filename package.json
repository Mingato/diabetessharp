{
  "name": "neurosharp",
  "version": "1.0.0",
  "private": true,
  "description": "Cognitive health app - Alzheimer prevention & memory recovery",
  "scripts": {
    "dev": "npm run build:shared && concurrently \"npm run dev:no-watch --workspace=server\" \"npm run dev:client\"",
    "dev:client-only": "npm run build:shared && npm run dev --workspace=client",
    "build:shared": "npm run build --workspace=shared",
    "dev:server": "npm run dev --workspace=server",
    "dev:server-only": "npm run build:shared && npm run dev:no-watch --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev:no-watch": "npm run dev:no-watch --workspace=server",
    "build": "npm run build --workspaces --if-present",
    "build:client": "npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "start": "npm run start --workspace=server",
    "db:migrate": "npm run db:migrate --workspace=server",
    "db:seed": "npm run db:seed --workspace=server",
    "test": "npm run test --workspaces --if-present"
  },
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20"
  }
}
